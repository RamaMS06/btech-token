{
  "$description": "Dark-mode semantic color overrides. Same alias structure as the light file — only the rung on the primitive ramp / brand ramp changes. Brand surfaces flip from .500/.600 to .400/.500 (lighter) so they remain readable on dark backgrounds. Status colors (success, error, warning, info) move from .700 (low-luminance text on light) to .300 (high-luminance text on dark).",
  "color": {
    "text": {
      "primary":   { "$value": "{color.neutral.100}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.400}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.500}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.800}", "$type": "color" },
      "disabled":  { "$value": "{color.neutral.600}", "$type": "color" },
      "link":      { "$value": "{color.teal.500}",    "$type": "color" },
      "success":   { "$value": "{color.green.300}",   "$type": "color" },
      "error":     { "$value": "{color.red.300}",     "$type": "color" },
      "warning":   { "$value": "{color.yellow.300}",  "$type": "color" },
      "info":      { "$value": "{color.sky.300}",     "$type": "color" }
    },
    "icon": {
      "primary":   { "$value": "{color.neutral.100}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.400}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.500}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.800}", "$type": "color" },
      "disabled":  { "$value": "{color.neutral.600}", "$type": "color" },
      "link":      { "$value": "{color.teal.500}",    "$type": "color" },
      "success":   { "$value": "{color.green.300}",   "$type": "color" },
      "error":     { "$value": "{color.red.300}",     "$type": "color" },
      "warning":   { "$value": "{color.yellow.300}",  "$type": "color" },
      "info":      { "$value": "{color.sky.300}",     "$type": "color" }
    },
    "border": {
      "primary":   { "$value": "{color.neutral.600}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.200}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.100}", "$type": "color" },
      "disabled":  { "$value": "{color.neutral.700}", "$type": "color" }
    },
    "bg": {
      "primary":   { "$value": "{color.neutral.800}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.700}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.100}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.100}", "$type": "color" },
      "subtle":    { "$value": "{color.neutral.800}", "$type": "color" },
      "subtler":   { "$value": "{color.neutral.600}", "$type": "color" },
      "subtlest":  { "$value": "{color.neutral.500}", "$type": "color" },
      "overlay":   { "$value": "#181c20cc",           "$type": "color", "$description": "Neutral.900 with 80% alpha; kept as a raw value because DTCG cannot express alpha-modified aliases." }
    },
    "brand": {
      "primary-subtle":   { "$value": "{brand.primary.800}",   "$type": "color" },
      "primary":          { "$value": "{brand.primary.400}",   "$type": "color" },
      "primary-bold":     { "$value": "{brand.primary.500}",   "$type": "color" },
      "secondary-subtle": { "$value": "{brand.secondary.800}", "$type": "color" },
      "secondary":        { "$value": "{brand.secondary.400}", "$type": "color" },
      "secondary-bold":   { "$value": "{brand.secondary.500}", "$type": "color" }
    },
    "ext": {
      "success-subtler": { "$value": "{color.green.500}",  "$type": "color" },
      "success-subtle":  { "$value": "{color.green.700}",  "$type": "color" },
      "success":         { "$value": "{color.green.400}",  "$type": "color" },
      "success-bold":    { "$value": "{color.green.50}",   "$type": "color" },
      "info-subtler":    { "$value": "{color.sky.500}",    "$type": "color" },
      "info-subtle":     { "$value": "{color.sky.700}",    "$type": "color" },
      "info":            { "$value": "{color.sky.400}",    "$type": "color" },
      "info-bold":       { "$value": "{color.sky.50}",     "$type": "color" },
      "warning-subtler": { "$value": "{color.yellow.500}", "$type": "color" },
      "warning-subtle":  { "$value": "{color.yellow.700}", "$type": "color" },
      "warning":         { "$value": "{color.yellow.400}", "$type": "color" },
      "warning-bold":    { "$value": "{color.yellow.50}",  "$type": "color" },
      "error-subtler":   { "$value": "{color.red.500}",    "$type": "color" },
      "error-subtle":    { "$value": "{color.red.700}",    "$type": "color" },
      "error":           { "$value": "{color.red.400}",    "$type": "color" },
      "error-bold":      { "$value": "{color.red.50}",     "$type": "color" }
    }
  }
}
