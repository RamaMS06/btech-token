{
  "$description": "Light-mode semantic color tokens. Every leaf aliases either a primitive hue ramp (for status / neutral colors that don't change per tenant) or the brand layer (for surfaces & accents that swap with the active tenant).",
  "color": {
    "text": {
      "primary":   { "$value": "{color.neutral.800}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":   { "$value": "{color.white}",   "$type": "color" },
      "disabled":  { "$value": "{color.neutral.300}", "$type": "color" },
      "link":      { "$value": "{color.teal.600}",    "$type": "color" },
      "success":   { "$value": "{color.green.700}",   "$type": "color" },
      "error":     { "$value": "{color.red.700}",     "$type": "color" },
      "warning":   { "$value": "{color.yellow.700}",  "$type": "color" },
      "info":      { "$value": "{color.sky.700}",     "$type": "color" }
    },
    "icon": {
      "primary":   { "$value": "{color.neutral.800}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":   { "$value": "{color.white}",   "$type": "color" },
      "disabled":  { "$value": "{color.neutral.300}", "$type": "color" },
      "link":      { "$value": "{color.teal.600}",    "$type": "color" },
      "success":   { "$value": "{color.green.700}",   "$type": "color" },
      "error":     { "$value": "{color.red.700}",     "$type": "color" },
      "warning":   { "$value": "{color.yellow.700}",  "$type": "color" },
      "info":      { "$value": "{color.sky.700}",     "$type": "color" }
    },
    "border": {
      "primary":   { "$value": "{color.neutral.200}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.400}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.300}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.800}", "$type": "color" },
      "disabled":  { "$value": "{color.neutral.300}", "$type": "color" }
    },
    "bg": {
      "primary":   { "$value": "{color.white}",   "$type": "color" },
      "secondary": { "$value": "{color.neutral.100}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.500}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.800}", "$type": "color" },
      "subtle":    { "$value": "{color.neutral.50}",  "$type": "color" },
      "subtler":   { "$value": "{color.neutral.200}", "$type": "color" },
      "subtlest":  { "$value": "{color.neutral.300}", "$type": "color" },
      "overlay":   { "$value": "#181c20cc",           "$type": "color", "$description": "Neutral.900 with 80% alpha; kept as a raw value because DTCG cannot express alpha-modified aliases." }
    },
    "brand": {
      "primary-subtle":   { "$value": "{color.brand.primary.50}",   "$type": "color" },
      "primary-default":  { "$value": "{color.brand.primary.500}",  "$type": "color" },
      "primary-bold":     { "$value": "{color.brand.primary.600}",  "$type": "color" },
      "secondary-subtle": { "$value": "{color.brand.secondary.50}", "$type": "color" },
      "secondary-default":{ "$value": "{color.brand.secondary.500}","$type": "color" },
      "secondary-bold":   { "$value": "{color.brand.secondary.600}","$type": "color" }
    },
    "ext": {
      "success-subtler": { "$value": "{color.green.100}",  "$type": "color" },
      "success-subtle":  { "$value": "{color.green.200}",  "$type": "color" },
      "success":         { "$value": "{color.green.500}",  "$type": "color" },
      "success-bold":    { "$value": "{color.green.600}",  "$type": "color" },
      "info-subtler":    { "$value": "{color.sky.100}",    "$type": "color" },
      "info-subtle":     { "$value": "{color.sky.200}",    "$type": "color" },
      "info":            { "$value": "{color.sky.500}",    "$type": "color" },
      "info-bold":       { "$value": "{color.sky.600}",    "$type": "color" },
      "warning-subtler": { "$value": "{color.yellow.100}", "$type": "color" },
      "warning-subtle":  { "$value": "{color.yellow.200}", "$type": "color" },
      "warning":         { "$value": "{color.yellow.500}", "$type": "color" },
      "warning-bold":    { "$value": "{color.yellow.600}", "$type": "color" },
      "error-subtler":   { "$value": "{color.red.100}",    "$type": "color" },
      "error-subtle":    { "$value": "{color.red.200}",    "$type": "color" },
      "error":           { "$value": "{color.red.500}",    "$type": "color" },
      "error-bold":      { "$value": "{color.red.600}",    "$type": "color" }
    }
  }
}
