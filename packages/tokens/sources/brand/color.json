{
  "$description": "Brand color ramps — middle layer between primitives and semantics. Each rung (50-900) aliases a primitive hue ramp. Tenant overrides re-target the aliases to swap brand hues without touching semantics or primitives.",
  "brand": {
    "primary": {
      "50":  { "$value": "{color.green.50}",  "$type": "color" },
      "100": { "$value": "{color.green.100}", "$type": "color" },
      "200": { "$value": "{color.green.200}", "$type": "color" },
      "300": { "$value": "{color.green.300}", "$type": "color" },
      "400": { "$value": "{color.green.400}", "$type": "color" },
      "500": { "$value": "{color.green.500}", "$type": "color" },
      "600": { "$value": "{color.green.600}", "$type": "color" },
      "700": { "$value": "{color.green.700}", "$type": "color" },
      "800": { "$value": "{color.green.800}", "$type": "color" },
      "900": { "$value": "{color.green.900}", "$type": "color" }
    },
    "secondary": {
      "50":  { "$value": "{color.teal.50}",  "$type": "color" },
      "100": { "$value": "{color.teal.100}", "$type": "color" },
      "200": { "$value": "{color.teal.200}", "$type": "color" },
      "300": { "$value": "{color.teal.300}", "$type": "color" },
      "400": { "$value": "{color.teal.400}", "$type": "color" },
      "500": { "$value": "{color.teal.500}", "$type": "color" },
      "600": { "$value": "{color.teal.600}", "$type": "color" },
      "700": { "$value": "{color.teal.700}", "$type": "color" },
      "800": { "$value": "{color.teal.800}", "$type": "color" },
      "900": { "$value": "{color.teal.900}", "$type": "color" }
    }
  }
}
