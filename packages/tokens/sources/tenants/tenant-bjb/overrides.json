{
  "$description": "Tenant BJB — green brand, custom font, tight radius",
  "color": {
    
    "brand": {
      "primary-subtle":   { "$value": "#f0f8f4", "$type": "color" },
      "primary":          { "$value": "#0a853e", "$type": "color" },
      "primary-bold":     { "$value": "#0a632f", "$type": "color" },
      "secondary-subtle": { "$value": "#f0f8f7", "$type": "color" },
      "secondary":        { "$value": "#0d766c", "$type": "color" },
      "secondary-bold":   { "$value": "#0c5852", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "Poppins, system-ui", "$type": "fontFamily" }
    }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "4px", "$type": "dimension" }
  }
}
