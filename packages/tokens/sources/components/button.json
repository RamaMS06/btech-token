{
  "button": {
    "primary": {
      "bg":       { "$value": "{color.brand.primary}",       "$type": "color" },
      "bgHover":  { "$value": "{color.brand.primary-bold}",  "$type": "color" },
      "fg":       { "$value": "{color.text.inverse}",        "$type": "color" },
      "border":   { "$value": "{color.brand.primary}",       "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",        "$type": "dimension" }
    },
    "secondary": {
      "bg":       { "$value": "{color.brand.primary-subtle}", "$type": "color" },
      "bgHover":  { "$value": "{color.bg.secondary}",         "$type": "color" },
      "fg":       { "$value": "{color.text.primary}",         "$type": "color" },
      "border":   { "$value": "{color.border.primary}",       "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",         "$type": "dimension" }
    },
    "danger": {
      "bg":       { "$value": "{color.ext.error}",           "$type": "color" },
      "bgHover":  { "$value": "{color.ext.error-bold}",      "$type": "color" },
      "fg":       { "$value": "{color.text.inverse}",        "$type": "color" },
      "border":   { "$value": "{color.ext.error}",           "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",        "$type": "dimension" }
    },
    "size": {
      "sm": {
        "paddingX":  { "$value": "{spacing.sm}",              "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.xs}",              "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.sm}",  "$type": "dimension" }
      },
      "md": {
        "paddingX":  { "$value": "{spacing.md}",              "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",              "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.md}",  "$type": "dimension" }
      },
      "lg": {
        "paddingX":  { "$value": "{spacing.lg}",              "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",              "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.lg}",  "$type": "dimension" }
      }
    }
  }
}
