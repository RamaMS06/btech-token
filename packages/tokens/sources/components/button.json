{
  "button": {
    "primary": {
      "bg":       { "$value": "{color.background.primary.default}",   "$type": "color" },
      "bgHover":  { "$value": "{color.background.primary.hover}",     "$type": "color" },
      "fg":       { "$value": "{color.text.neutral.inverse}",          "$type": "color" },
      "border":   { "$value": "{color.stroke.primary.default}",       "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",                 "$type": "dimension" }
    },
    "secondary": {
      "bg":       { "$value": "{color.background.secondary.default}", "$type": "color" },
      "bgHover":  { "$value": "{color.background.secondary.hover}",   "$type": "color" },
      "fg":       { "$value": "{color.text.neutral.default}",          "$type": "color" },
      "border":   { "$value": "{color.stroke.neutral.default}",       "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",                 "$type": "dimension" }
    },
    "danger": {
      "bg":       { "$value": "{color.background.danger.default}",    "$type": "color" },
      "bgHover":  { "$value": "{color.background.danger.hover}",      "$type": "color" },
      "fg":       { "$value": "{color.text.neutral.inverse}",          "$type": "color" },
      "border":   { "$value": "{color.stroke.danger.default}",        "$type": "color" },
      "radius":   { "$value": "{radius.interactive}",                 "$type": "dimension" }
    },
    "size": {
      "sm": {
        "paddingX":  { "$value": "{spacing.sm}",                       "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.xs}",                       "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.sm}",           "$type": "dimension" }
      },
      "md": {
        "paddingX":  { "$value": "{spacing.md}",                       "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",                       "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.base}",         "$type": "dimension" }
      },
      "lg": {
        "paddingX":  { "$value": "{spacing.lg}",                       "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",                       "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.lg}",           "$type": "dimension" }
      }
    }
  }
}
