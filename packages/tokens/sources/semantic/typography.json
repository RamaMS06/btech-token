{
  "typography": {
    "body": {
      "fontFamily": { "$value": "{typography.fontFamily.sans}", "$type": "fontFamily" },
      "fontSize":   { "$value": "{typography.fontSize.md}",      "$type": "dimension" },
      "fontWeight": { "$value": "{typography.fontWeight.regular}", "$type": "fontWeight" },
      "lineHeight": { "$value": "{typography.lineHeight.md}",     "$type": "number" }
    },
    "label": {
      "fontFamily": { "$value": "{typography.fontFamily.sans}", "$type": "fontFamily" },
      "fontSize":   { "$value": "{typography.fontSize.sm}",    "$type": "dimension" },
      "fontWeight": { "$value": "{typography.fontWeight.medium}", "$type": "fontWeight" },
      "lineHeight": { "$value": "{typography.lineHeight.sm}",   "$type": "number" }
    },
    "heading": {
      "fontFamily": { "$value": "{typography.fontFamily.sans}", "$type": "fontFamily" },
      "fontWeight": { "$value": "{typography.fontWeight.bold}", "$type": "fontWeight" },
      "lineHeight": { "$value": "{typography.lineHeight.sm}",   "$type": "number" }
    },
    "code": {
      "fontFamily": { "$value": "{typography.fontFamily.mono}", "$type": "fontFamily" },
      "fontSize":   { "$value": "{typography.fontSize.sm}",    "$type": "dimension" }
    },
    "typeScale": {
      "heading": {
        "display": {
          "fontSize":     { "$value": "40px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "48px", "$type": "dimension" }
        },
        "h1": {
          "fontSize":     { "$value": "32px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "40px", "$type": "dimension" }
        },
        "h2": {
          "fontSize":     { "$value": "28px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "36px", "$type": "dimension" }
        },
        "h3": {
          "fontSize":     { "$value": "24px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "32px", "$type": "dimension" }
        },
        "h4": {
          "fontSize":     { "$value": "20px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "28px", "$type": "dimension" }
        }
      },
      "subheading": {
        "h5": {
          "fontSize":     { "$value": "18px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "24px", "$type": "dimension" }
        },
        "h6": {
          "fontSize":     { "$value": "16px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "20px", "$type": "dimension" }
        },
        "h7": {
          "fontSize":     { "$value": "14px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "16px", "$type": "dimension" }
        },
        "h8": {
          "fontSize":     { "$value": "12px", "$type": "dimension" },
          "fontWeight":   { "$value": 600,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "16px", "$type": "dimension" }
        }
      },
      "body": {
        "large": {
          "fontSize":     { "$value": "16px", "$type": "dimension" },
          "fontWeight":   { "$value": 400,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "20px", "$type": "dimension" }
