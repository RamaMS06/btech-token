          "lineHeightPx": { "$value": "20px", "$type": "dimension" }
        },
        "regularB": {
          "fontSize":     { "$value": "14px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "16px", "$type": "dimension" }
        },
        "smallB": {
          "fontSize":     { "$value": "12px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "16px", "$type": "dimension" }
        },
        "xtrasmallB": {
          "fontSize":     { "$value": "10px", "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "16px", "$type": "dimension" }
        },
        "microB": {
          "fontSize":     { "$value": "8px",  "$type": "dimension" },
          "fontWeight":   { "$value": 700,    "$type": "fontWeight" },
          "lineHeightPx": { "$value": "12px", "$type": "dimension" }
        }
      }
    }
  }
}
