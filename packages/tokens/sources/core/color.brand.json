{
  "$description": "Brand color ramps — middle layer between primitives and semantics. Each rung (50-900) aliases a primitive hue ramp. Tenant overrides re-target the aliases to swap brand hues without touching semantics or primitives.",
  "color": {
    "brand": {
      "primary": {
        "50":  { "$value": "{color.blue.50}",  "$type": "color" },
        "100": { "$value": "{color.blue.100}", "$type": "color" },
        "200": { "$value": "{color.blue.200}", "$type": "color" },
        "300": { "$value": "{color.blue.300}", "$type": "color" },
        "400": { "$value": "{color.blue.400}", "$type": "color" },
        "500": { "$value": "{color.blue.500}", "$type": "color" },
        "600": { "$value": "{color.blue.600}", "$type": "color" },
        "700": { "$value": "{color.blue.700}", "$type": "color" },
        "800": { "$value": "{color.blue.800}", "$type": "color" },
        "900": { "$value": "{color.blue.900}", "$type": "color" }
      },
      "secondary": {
        "50":  { "$value": "{color.amber.50}",  "$type": "color" },
        "100": { "$value": "{color.amber.100}", "$type": "color" },
        "200": { "$value": "{color.amber.200}", "$type": "color" },
        "300": { "$value": "{color.amber.300}", "$type": "color" },
        "400": { "$value": "{color.amber.400}", "$type": "color" },
        "500": { "$value": "{color.amber.500}", "$type": "color" },
        "600": { "$value": "{color.amber.600}", "$type": "color" },
        "700": { "$value": "{color.amber.700}", "$type": "color" },
        "800": { "$value": "{color.amber.800}", "$type": "color" },
        "900": { "$value": "{color.amber.900}", "$type": "color" }
      }
    }
  }
}
