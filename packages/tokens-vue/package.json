{
  "name": "@btech/tokens-vue",
  "version": "0.0.1",
  "description": "Multi-tenant design tokens for Vue 3 — generated by @btech/design-tokens",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vue": "^3.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
