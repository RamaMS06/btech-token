#!/usr/bin/env sh
# pre-commit — auto-generate token outputs when tokens/ sources or generators change.
#
# Runs automatically before every commit.
# Only re-generates if staged files include packages/tokens/sources/, generators/, or sd.config.ts.
# Generated files are staged automatically so they land in the same commit.

set -e

STAGED=$(git diff --cached --name-only)
NEEDS_GENERATE=$(echo "$STAGED" | grep -E '^packages/tokens/(sources|generators|sd\.config\.ts)' || true)

if [ -z "$NEEDS_GENERATE" ]; then
  exit 0
fi

echo "🔄  Token source changed — regenerating packages..."

pnpm exec tsx packages/tokens/sd.config.ts

git add \
  packages/tokens/platforms/flutter/lib/btech_tokens.dart \
  packages/tokens/platforms/flutter/lib/src/color/ \
  packages/tokens/platforms/flutter/lib/src/spacing/ \
  packages/tokens/platforms/flutter/lib/src/radius/ \
  packages/tokens/platforms/flutter/lib/src/font/ \
  packages/tokens/platforms/flutter/lib/src/typography/ \
  packages/tokens/platforms/flutter/lib/src/theme_builder.dart \
  packages/tokens/platforms/flutter/lib/src/context.dart \
  packages/tokens/platforms/flutter/tenants/ \
  packages/tokens/platforms/web/src/ \
  packages/tokens/platforms/web/dist/styles.css \
  2>/dev/null || true

echo "✅  Generated outputs staged."
