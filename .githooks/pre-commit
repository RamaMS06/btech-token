#!/usr/bin/env sh
# pre-commit — auto-generate token outputs when tokens/ sources or generators change.
#
# Runs automatically before every commit.
# Only re-generates if staged files include packages/tokens/sources/, generators/, or sd.config.ts.
# Generated files are staged automatically so they land in the same commit.
#
# Framework-agnostic: stages the entire packages/tokens/platforms/ tree so that
# adding a new output platform (iOS, Android, etc.) requires no changes here.

set -e

STAGED=$(git diff --cached --name-only)
NEEDS_GENERATE=$(echo "$STAGED" | grep -E '^packages/tokens/(sources|generators|sd\.config\.ts)' || true)

if [ -z "$NEEDS_GENERATE" ]; then
  exit 0
fi

echo "🔄  Token source changed — regenerating packages..."

pnpm exec tsx packages/tokens/sd.config.ts

# Stage all generated platform outputs at once.
# platforms/ is 100% generated — no hand-edited files live here.
git add packages/tokens/platforms/ 2>/dev/null || true

# Resolve dependencies for ALL Flutter packages (base + every tenant, including newly generated ones).
# melos discovers packages via the glob in melos.yaml — no need to manually loop tenant dirs.
dart run melos get --no-select 2>/dev/null || true

echo "✅  Generated outputs staged."
