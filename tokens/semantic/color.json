{
  "color": {
    "primary": {
      "bg":     { "$value": "{color.green.500}", "$type": "color", "$description": "Main brand background — overridable per tenant" },
      "bg-hover": { "$value": "{color.green.600}", "$type": "color" },
      "fg":     { "$value": "{color.neutral.0}",   "$type": "color" },
      "border": { "$value": "{color.green.600}", "$type": "color" }
    },
    "secondary": {
      "bg":     { "$value": "{color.neutral.100}", "$type": "color" },
      "bg-hover": { "$value": "{color.neutral.200}", "$type": "color" },
      "fg":     { "$value": "{color.neutral.800}", "$type": "color" },
      "border": { "$value": "{color.neutral.300}", "$type": "color" }
    },
    "danger": {
      "bg":     { "$value": "{color.red.500}", "$type": "color" },
      "bg-hover": { "$value": "{color.red.600}", "$type": "color" },
      "fg":     { "$value": "{color.neutral.0}", "$type": "color" },
      "border": { "$value": "{color.red.700}", "$type": "color" }
    },
    "success": {
      "bg":     { "$value": "{color.green.500}", "$type": "color" },
      "fg":     { "$value": "{color.neutral.0}", "$type": "color" }
    },
    "warning": {
      "bg":     { "$value": "{color.orange.500}", "$type": "color" },
      "fg":     { "$value": "{color.neutral.0}", "$type": "color" }
    },
    "surface": {
      "default": { "$value": "{color.neutral.0}",   "$type": "color" },
      "subtle":  { "$value": "{color.neutral.50}",  "$type": "color" },
      "raised":  { "$value": "{color.neutral.100}", "$type": "color" }
    },
    "text": {
      "default":  { "$value": "{color.neutral.900}", "$type": "color" },
      "subtle":   { "$value": "{color.neutral.500}", "$type": "color" },
      "disabled": { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":  { "$value": "{color.neutral.0}",   "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.neutral.200}", "$type": "color" },
      "strong":  { "$value": "{color.neutral.400}", "$type": "color" }
    }
  }
}
