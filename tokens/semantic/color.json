{
  "color": {
    "text": {
      "primary":   { "$value": "{color.neutral.900}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "disable":   { "$value": "{color.neutral.400}", "$type": "color" },
      "inverse":   { "$value": "{color.neutral.0}",   "$type": "color" },
      "on-primary": { "$value": "{color.neutral.0}",  "$type": "color" },
      "on-secondary": { "$value": "{color.neutral.800}", "$type": "color" },
      "on-danger":  { "$value": "{color.neutral.0}",  "$type": "color" }
    },
    "background": {
      "default":          { "$value": "{color.neutral.0}",   "$type": "color" },
      "subtle":           { "$value": "{color.neutral.50}",  "$type": "color" },
      "raised":           { "$value": "{color.neutral.100}", "$type": "color" },
      "primary":          { "$value": "{color.green.700}",   "$type": "color", "$description": "Main brand bg — WCAG AA with white text (5.02:1)" },
      "primary-hover":    { "$value": "{color.green.800}",   "$type": "color" },
      "secondary":        { "$value": "{color.neutral.100}", "$type": "color" },
      "secondary-hover":  { "$value": "{color.neutral.200}", "$type": "color" },
      "danger":           { "$value": "{color.red.700}",     "$type": "color" },
      "danger-hover":     { "$value": "{color.red.700}",     "$type": "color" },
      "success":          { "$value": "{color.green.500}",   "$type": "color" },
      "warning":          { "$value": "{color.orange.500}",  "$type": "color" }
    },
    "stroke": {
      "default":   { "$value": "{color.neutral.200}", "$type": "color" },
      "strong":    { "$value": "{color.neutral.400}", "$type": "color" },
      "primary":   { "$value": "{color.green.800}",   "$type": "color" },
      "secondary": { "$value": "{color.neutral.300}", "$type": "color" },
      "danger":    { "$value": "{color.red.700}",     "$type": "color" }
    }
  }
}
