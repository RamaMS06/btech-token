{
  "$description": "Tenant BJB — deeper blue brand, custom font, tight radius",
  "color": {
    "background": {
      "primary":       { "$value": "{color.red.600}", "$type": "color" },
      "primary-hover": { "$value": "{color.blue.700}", "$type": "color" }
    },
    "stroke": {
      "primary":       { "$value": "{color.blue.800}", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "'BJB Sans', Inter, system-ui, sans-serif", "$type": "fontFamily" }
    }
  },
  "radius": {
    "interactive": { "$value": "4px", "$type": "dimension" },
    "card":        { "$value": "4px", "$type": "dimension" }
  }
}
