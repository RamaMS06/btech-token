{
  "button": {
    "primary": {
      "bg":        { "$value": "{color.primary.bg}",     "$type": "color" },
      "bg-hover":  { "$value": "{color.primary.bg-hover}", "$type": "color" },
      "fg":        { "$value": "{color.primary.fg}",     "$type": "color" },
      "border":    { "$value": "{color.primary.border}", "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",   "$type": "dimension" }
    },
    "secondary": {
      "bg":        { "$value": "{color.secondary.bg}",       "$type": "color" },
      "bg-hover":  { "$value": "{color.secondary.bg-hover}", "$type": "color" },
      "fg":        { "$value": "{color.secondary.fg}",       "$type": "color" },
      "border":    { "$value": "{color.secondary.border}",   "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",       "$type": "dimension" }
    },
    "danger": {
      "bg":        { "$value": "{color.danger.bg}",       "$type": "color" },
      "bg-hover":  { "$value": "{color.danger.bg-hover}", "$type": "color" },
      "fg":        { "$value": "{color.danger.fg}",       "$type": "color" },
      "border":    { "$value": "{color.danger.border}",   "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",    "$type": "dimension" }
    },
    "size": {
      "sm": {
        "paddingX":  { "$value": "{spacing.scale.3}", "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.scale.1}", "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.sm}", "$type": "dimension" }
      },
      "md": {
        "paddingX":  { "$value": "{spacing.scale.4}", "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.scale.2}", "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.base}", "$type": "dimension" }
      },
      "lg": {
        "paddingX":  { "$value": "{spacing.scale.6}", "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.scale.3}", "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.lg}", "$type": "dimension" }
      }
    }
  }
}
