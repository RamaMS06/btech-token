{
  "button": {
    "primary": {
      "bg":        { "$value": "{color.background.primary}",       "$type": "color" },
      "bg-hover":  { "$value": "{color.background.primary-hover}", "$type": "color" },
      "fg":        { "$value": "{color.text.on-primary}",          "$type": "color" },
      "border":    { "$value": "{color.stroke.primary}",           "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",             "$type": "dimension" }
    },
    "secondary": {
      "bg":        { "$value": "{color.background.secondary}",       "$type": "color" },
      "bg-hover":  { "$value": "{color.background.secondary-hover}", "$type": "color" },
      "fg":        { "$value": "{color.text.on-secondary}",          "$type": "color" },
      "border":    { "$value": "{color.stroke.secondary}",           "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",               "$type": "dimension" }
    },
    "danger": {
      "bg":        { "$value": "{color.background.danger}",       "$type": "color" },
      "bg-hover":  { "$value": "{color.background.danger-hover}", "$type": "color" },
      "fg":        { "$value": "{color.text.on-danger}",          "$type": "color" },
      "border":    { "$value": "{color.stroke.danger}",           "$type": "color" },
      "radius":    { "$value": "{radius.interactive}",            "$type": "dimension" }
    },
    "size": {
      "sm": {
        "paddingX":  { "$value": "{spacing.sm}",                   "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.xs}",                   "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.sm}",       "$type": "dimension" }
      },
      "md": {
        "paddingX":  { "$value": "{spacing.md}",                   "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",                   "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.base}",     "$type": "dimension" }
      },
      "lg": {
        "paddingX":  { "$value": "{spacing.lg}",                   "$type": "dimension" },
        "paddingY":  { "$value": "{spacing.sm}",                   "$type": "dimension" },
        "fontSize":  { "$value": "{typography.fontSize.lg}",       "$type": "dimension" }
      }
    }
  }
}
