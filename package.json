{
  "name": "@btech/design-tokens",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "Multi-tenant design token source of truth — React, Vue, Flutter",
  "scripts": {
    "generate": "tsx config/sd.config.ts",
    "build": "pnpm generate && turbo run build",
    "validate": "tsx tools/validators/contrast.ts && tsx tools/validators/boundary.ts",
    "add-tenant": "tsx scripts/add-tenant.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.0.0",
    "style-dictionary": "^4.3.0",
    "tsx": "^4.7.2",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5"
  }
}
