{
  "name": "@btech/design-tokens",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "Multi-tenant design token source of truth — React, Vue, Flutter",
  "scripts": {
    "generate": "pnpm exec tsx config/sd.config.ts",
    "build": "pnpm generate && turbo run build",
    "validate": "pnpm exec tsx tools/validators/contrast.ts && pnpm exec tsx tools/validators/boundary.ts",
    "add-tenant": "pnpm exec tsx scripts/add-tenant.ts",
    "bootstrap": "pnpm install && melos bootstrap",
    "flutter:get": "melos run get",
    "flutter:analyze": "melos run analyze",
    "flutter:test": "melos run test",
    "sync-dart-version": "pnpm exec tsx scripts/sync-dart-version.ts",
    "changeset": "changeset",
    "version": "changeset version && pnpm sync-dart-version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.0.0",
    "style-dictionary": "^4.3.0",
    "tsx": "^4.7.2",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5"
  }
}
