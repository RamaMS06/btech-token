  "title": "BTAvatarGroup",
  "description": "Stacked group of BTAvatar instances with horizontal negative-margin overlap. Renders a \"+N\" overflow counter when items exceed `max`. Stacking offsets match Figma 504:705 specs (8/10/12/16/20/32 px per size).",
  "framework": "vue",
  "category": "organisms",
  "figmaUrl": "https://www.figma.com/design/WANr9drWYNYbMPuT2sMeHi/Btech---Design-System?node-id=504-705",
  "figmaNodeId": "504:705",
  "dependencies": [
    "@btech/tokens"
