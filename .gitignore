# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
**/dist/
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts
*.tsbuildinfo

# ── Dart / Flutter — packages/ ────────────────────────────────────────────────
# pubspec.lock for libraries is intentionally NOT committed (pub resolves at consumer side)
packages/**/pubspec.lock
packages/**/.dart_tool/
packages/**/build/
packages/**/.flutter-plugins
packages/**/.flutter-plugins-dependencies

# ── Root-level Dart tooling ────────────────────────────────────────────────────
.dart_tool/
build/

# ── Env / secrets ─────────────────────────────────────────────────────────────
# .npmrc is committed — it contains only registry config, no secrets.
# Auth tokens are injected at runtime via ${NODE_AUTH_TOKEN} env var.
.env
.env.*
.env.local
.env.*.local

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Tenant generated outputs — regenerated on every publish run ───────────────
# Web tenant: only package.json + src/ committed; dist/ generated by pipeline
packages/platforms/web/tenants/*/dist/
# Flutter tenant: pubspec.lock + build artifacts excluded
packages/platforms/flutter/tenants/*/build/
packages/platforms/flutter/tenants/*/.dart_tool/
packages/platforms/flutter/tenants/*/pubspec.lock
# Flutter base platform build artifacts
packages/platforms/flutter/build/
packages/platforms/flutter/.dart_tool/

# ── Demo apps — local only, not published ─────────────────────────────────────
apps/

# ── Changesets ────────────────────────────────────────────────────────────────
.changeset/*.js
