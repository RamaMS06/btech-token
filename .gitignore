# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
**/dist/
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts
*.tsbuildinfo

# ── Dart / Flutter — packages/ ────────────────────────────────────────────────
# pubspec.lock for libraries is intentionally NOT committed (pub resolves at consumer side)
packages/**/pubspec.lock
packages/**/.dart_tool/
packages/**/build/
packages/**/.flutter-plugins
packages/**/.flutter-plugins-dependencies

# ── Root-level Dart tooling ────────────────────────────────────────────────────
.dart_tool/
build/

# ── Env / secrets ─────────────────────────────────────────────────────────────
# .npmrc is committed — it contains only registry config, no secrets.
# Auth tokens are injected at runtime via ${NODE_AUTH_TOKEN} env var.
.env
.env.*
.env.local
.env.*.local

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Tenant generated outputs — regenerated on every publish run ───────────────
# Only package.json + src/ are committed; dist/ is always generated by pipeline
packages/tenants/*/dist/
platforms/flutter/tenants/*/build/
platforms/flutter/tenants/*/.dart_tool/
platforms/flutter/tenants/*/pubspec.lock

# ── Demo apps — local only, not published ─────────────────────────────────────
apps/

# ── Changesets ────────────────────────────────────────────────────────────────
.changeset/*.js
