# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
**/dist/
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts
*.tsbuildinfo

# ── Vite / demo apps dev artifacts ───────────────────────────────────────────
apps/**/.vite/
apps/**/coverage/
apps/**/*.local

# ── Dart / Flutter — libraries (packages/) ────────────────────────────────────
# pubspec.lock for libraries is intentionally NOT committed (pub resolves at consumer side)
packages/**/pubspec.lock
packages/**/.dart_tool/
packages/**/build/
packages/**/.flutter-plugins
packages/**/.flutter-plugins-dependencies

# ── Dart / Flutter — apps (apps/) ─────────────────────────────────────────────
# pubspec.lock for apps IS committed (reproducible builds) — do NOT add it here
apps/**/.dart_tool/
apps/**/build/
apps/**/.flutter-plugins
apps/**/.flutter-plugins-dependencies
apps/**/.metadata

# ── Root-level Dart tooling ────────────────────────────────────────────────────
.dart_tool/
build/

# ── Env / secrets ─────────────────────────────────────────────────────────────
# .npmrc is committed — it contains only registry config, no secrets.
# Auth tokens are injected at runtime via ${NODE_AUTH_TOKEN} env var.
.env
.env.*
.env.local
.env.*.local

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Changesets ────────────────────────────────────────────────────────────────
.changeset/*.js
