# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
# Web dist/ is NEVER committed — it is regenerated in CI (pipelines/*.yml) and
# included in published tarballs via each package's `files: ["dist"]`.
# Consumers get dist via the npm registry, not git.
#
# Flutter is the opposite: Dart artifacts live in `lib/src/` (not `dist/`) and
# ARE committed because Flutter consumers depend on us via `git` path.
dist/
**/dist/
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts
*.tsbuildinfo

# ── Dart / Flutter — packages/ ────────────────────────────────────────────────
# pubspec.lock for libraries is intentionally NOT committed (pub resolves at consumer side)
packages/**/pubspec.lock
packages/**/.dart_tool/
packages/**/build/
packages/**/.flutter-plugins
packages/**/.flutter-plugins-dependencies


# ── Root-level Dart tooling (Melos workspace) ─────────────────────────────────
# pubspec.lock at root is for the Melos workspace — not a published package, not committed.
pubspec.lock
.dart_tool/
build/

# ── Env / secrets ─────────────────────────────────────────────────────────────
# .npmrc is committed — it contains only registry config, no secrets.
# Auth tokens are injected at runtime via ${NODE_AUTH_TOKEN} env var.
.env
.env.*
.env.local
.env.*.local

# ── Git worktrees ─────────────────────────────────────────────────────────────
.worktrees/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Demo apps — entirely local, never committed to git ────────────────────────
# apps/

# ── Changesets ────────────────────────────────────────────────────────────────
.changeset/*.js
# Added by code-review-graph
.code-review-graph/

# ── Graph viz — internal tool, never committed to main ────────────────────────
# tools/graph-viz/ is an on-demand xyflow visualization of the
# code-review-graph MCP cache. It is developer-local only — not part of
# the published design system.
tools/graph-viz/
code-review-graph.zip
